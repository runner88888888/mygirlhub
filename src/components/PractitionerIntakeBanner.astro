---
import { LISTING_APPLICATION } from '../data/apply';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<aside
  class:list={[
    'overflow-hidden rounded-2xl border border-sage/25 bg-gradient-to-br from-sage/15 via-cream to-stone/50',
    compact ? 'p-8' : 'p-8 sm:p-12',
  ]}
  aria-labelledby="intake-heading"
>
  <p class="text-xs font-semibold uppercase tracking-widest text-sage">For practitioners</p>
  <h2 id="intake-heading" class="mt-3 font-serif text-2xl font-semibold text-ink sm:text-3xl">
    Are you a qualified female therapist, coach, or wellness practitioner?
  </h2>
  <p class="mt-4 max-w-2xl text-sm leading-relaxed text-ink/80 sm:text-base">
    Join the MyGirlHub network to get your practice in front of thousands of high-intent clients. We
    accept verified applications from certified professionals globally — credentials reviewed before
    any profile goes live.
  </p>
  <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
    <a
      href="/apply/"
      class="inline-flex items-center justify-center rounded-xl bg-sage px-6 py-3 text-sm font-semibold text-cream transition hover:bg-sage-dark focus-visible:ring-2 focus-visible:ring-sage focus-visible:ring-offset-2"
    >
      Apply to Get Listed
    </a>
  </div>
</aside>
