---
import { shopProducts } from '../data/shop';

interface Props {
  compact?: boolean;
  showViewAll?: boolean;
}

const { compact = false, showViewAll = true } = Astro.props;
const products = compact ? shopProducts.slice(0, 3) : shopProducts;
---

<section
  class="py-16"
  aria-labelledby="curated-edit-heading"
  id="curated-wellness-edit"
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <p class="text-sm font-medium uppercase tracking-widest text-sage-light">Curated for you</p>
        <h2 id="curated-edit-heading" class="mt-2 font-serif text-3xl font-semibold text-ink sm:text-4xl">
          The Curated Wellness Edit
        </h2>
        <p class="mt-3 text-ink/75">
          Tools we genuinely recommend — digital planners, evidence-backed reads, and vetted self-care
          essentials. Some links are affiliate partnerships; you never pay more.
        </p>
      </div>
      {
        showViewAll && compact && (
          <a
            href="/shop/"
            class="inline-flex shrink-0 items-center text-sm font-semibold text-sage hover:underline"
          >
            View full shop →
          </a>
        )
      }
    </div>

    <ul class:list={['mt-10 grid gap-8', compact ? 'md:grid-cols-3' : 'sm:grid-cols-2 lg:grid-cols-2']}>
      {
        products.map((product) => (
          <li
            class:list={[
              'flex flex-col overflow-hidden rounded-2xl border bg-cream shadow-sm transition hover:shadow-md',
              product.highlight ? 'border-sage/40 ring-1 ring-sage/20' : 'border-stone',
              !compact && product.highlight && 'lg:col-span-2 lg:flex-row',
            ]}
          >
            <div
              class:list={[
                'relative shrink-0 overflow-hidden bg-stone',
                compact ? 'aspect-[4/3]' : product.highlight ? 'lg:w-2/5 lg:aspect-auto lg:min-h-[280px]' : 'aspect-[16/10]',
              ]}
            >
              <img
                src={product.image}
                alt={product.imageAlt}
                class="h-full w-full object-cover"
                loading="lazy"
                width="600"
                height="400"
              />
              {product.badge && (
                <span class="absolute left-4 top-4 rounded-full bg-cream/95 px-3 py-1 text-xs font-semibold text-sage shadow-sm">
                  {product.badge}
                </span>
              )}
            </div>
            <div class="flex flex-1 flex-col p-6 sm:p-8">
              <p class="text-xs font-semibold uppercase tracking-wide text-sage-light">
                {product.type === 'digital' ? 'Direct download' : 'Affiliate partner'}
              </p>
              <h3 class="mt-2 font-serif text-xl font-semibold text-ink sm:text-2xl">{product.title}</h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-ink/75">{product.description}</p>
              {product.price && (
                <p class="mt-4">
                  <span class="font-serif text-2xl font-semibold text-sage">{product.price}</span>
                  {product.priceNote && (
                    <span class="ml-2 text-sm text-ink/50">{product.priceNote}</span>
                  )}
                </p>
              )}
              <a
                href={product.ctaHref}
                target={product.ctaExternal ? '_blank' : undefined}
                rel={product.ctaExternal ? 'noopener noreferrer sponsored' : undefined}
                class:list={[
                  'mt-6 inline-flex items-center justify-center rounded-xl px-6 py-3 text-sm font-semibold transition focus-visible:ring-2 focus-visible:ring-sage focus-visible:ring-offset-2',
                  product.type === 'digital'
                    ? 'bg-sage text-cream hover:bg-sage-dark'
                    : 'border border-sage/30 bg-cream text-sage hover:bg-stone/50',
                ]}
              >
                {product.ctaLabel}
                {product.ctaExternal && <span class="ml-1" aria-hidden="true">↗</span>}
              </a>
            </div>
          </li>
        ))
      }
    </ul>

    {!compact && (
      <p class="mt-10 text-center text-xs text-ink/50">
        As an Amazon Associate and affiliate partner, MyGirlHub may earn from qualifying purchases.
        <a href="/disclaimer/" class="ml-1 underline hover:text-sage">Full disclosures</a>
      </p>
    )}
  </div>
</section>
