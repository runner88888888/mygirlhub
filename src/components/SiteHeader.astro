---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/directory/', label: 'Directory' },
  { href: '/disclaimer/', label: 'Legal' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-stone/80 bg-cream/95 backdrop-blur-sm sticky top-0 z-40">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href="/" class="group flex flex-col gap-0.5" aria-label="MyGirlHub home">
      <span class="font-serif text-xl font-semibold tracking-tight text-sage sm:text-2xl">
        MyGirlHub
      </span>
      <span class="text-xs text-ink/60 sm:text-sm">Wellness · Mental Health · Self-Care</span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-6 md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-sage',
              currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                ? 'text-sage'
                : 'text-ink/70',
            ]}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <details class="relative md:hidden">
      <summary
        class="list-none cursor-pointer rounded-lg border border-stone bg-stone/50 px-3 py-2 text-sm font-medium text-ink [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        Menu
      </summary>
      <nav
        aria-label="Mobile"
        class="absolute right-0 top-full mt-2 min-w-[10rem] rounded-xl border border-stone bg-cream p-2 shadow-lg"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="block rounded-lg px-3 py-2 text-sm font-medium text-ink/80 hover:bg-stone hover:text-sage"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
