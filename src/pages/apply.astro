---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { LISTING_APPLICATION } from '../data/apply';
---

<BaseLayout
  title="Apply to Get Listed — MyGirlHub Practitioner Network"
  description="Submit your credentials to join the MyGirlHub wellness directory. Verified female therapists, coaches, and practitioners worldwide."
>
  <SiteHeader slot="header" />

  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:py-16 lg:px-8">
    <header>
      <p class="text-sm font-medium uppercase tracking-widest text-sage-light">Practitioner intake</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold text-ink">Apply to get listed</h1>
      <p class="mt-4 text-lg leading-relaxed text-ink/75">
        MyGirlHub is building a curated directory of <strong>real, verified</strong> female wellness
        professionals. Complete the steps below — we review every application before publishing.
      </p>
    </header>

    <ol class="mt-12 space-y-8">
      <li class="flex gap-4 rounded-2xl border border-stone bg-cream p-6">
        <span
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-sage font-semibold text-cream"
          aria-hidden="true"
        >
          1
        </span>
        <div>
          <h2 class="font-serif text-xl font-semibold text-ink">Submit your application</h2>
          <p class="mt-2 text-sm leading-relaxed text-ink/75">
            Provide your name, credentials, specialty, location, bio, website, and proof of certification
            (ICF, AHPRA, or equivalent). Applications are reviewed within 5–7 business days.
          </p>
          <a
            href={LISTING_APPLICATION.formUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center rounded-xl bg-sage px-5 py-2.5 text-sm font-semibold text-cream hover:bg-sage-dark"
          >
            Open application form
            <span class="sr-only"> (opens in new tab)</span>
            <span aria-hidden="true" class="ml-1">↗</span>
          </a>
        </div>
      </li>

      <li class="flex gap-4 rounded-2xl border border-stone bg-cream p-6">
        <span
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-sage font-semibold text-cream"
          aria-hidden="true"
        >
          2
        </span>
        <div>
          <h2 class="font-serif text-xl font-semibold text-ink">Listing review fee</h2>
          <p class="mt-2 text-sm leading-relaxed text-ink/75">
            A one-time <strong>{LISTING_APPLICATION.listingFeeLabel}</strong> covers credential verification
            and profile setup when approved. Pay only after you receive an acceptance email — or include
            payment reference in your form if you use a combined Stripe + form workflow.
          </p>
          <a
            href={LISTING_APPLICATION.listingFeeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center rounded-xl border border-sage/30 px-5 py-2.5 text-sm font-semibold text-sage hover:bg-stone/50"
          >
            Pay listing fee (Stripe)
            <span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>
      </li>

      <li class="flex gap-4 rounded-2xl border border-stone bg-cream p-6">
        <span
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-sage font-semibold text-cream"
          aria-hidden="true"
        >
          3
        </span>
        <div>
          <h2 class="font-serif text-xl font-semibold text-ink">Go live on the directory</h2>
          <p class="mt-2 text-sm leading-relaxed text-ink/75">
            Approved profiles receive a dedicated listing with photo, credentials badge, and booking link.
            Questions? Email{' '}
            <a href={`mailto:${LISTING_APPLICATION.contactEmail}`} class="font-medium text-sage hover:underline">
              {LISTING_APPLICATION.contactEmail}
            </a>
          </p>
        </div>
      </li>
    </ol>

    <p class="mt-10 rounded-xl border border-sage/20 bg-sage/5 p-4 text-xs leading-relaxed text-ink/70">
      By applying, you confirm your qualifications are accurate and you hold appropriate insurance where
      required. MyGirlHub does not endorse clinical outcomes and is not liable for services you provide.
      <a href="/disclaimer/" class="font-medium text-sage hover:underline">Full legal disclaimers</a>
    </p>

    <p class="mt-6 text-center">
      <a href="/directory/" class="text-sm font-semibold text-sage hover:underline">← Back to directory</a>
    </p>
  </div>

  <SiteFooter slot="footer" />
</BaseLayout>
