---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import MedicalDisclaimerBanner from '../../components/MedicalDisclaimerBanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-AU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`${post.data.title} — MyGirlHub`}
  description={post.data.description}
  ogImage={post.data.ogImage ?? post.data.image}
  ogType="article"
>
  <SiteHeader slot="header" />

  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:py-16">
    {
      post.data.image && (
        <div class="-mx-4 mb-10 overflow-hidden rounded-2xl sm:mx-0">
          <img
            src={post.data.image}
            alt={post.data.title}
            class="aspect-[2/1] w-full object-cover"
            width="1200"
            height="600"
          />
        </div>
      )
    }
    <header class="border-b border-stone pb-10">
      <p class="text-sm font-semibold uppercase tracking-wide text-sage-light">{post.data.category}</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold leading-tight text-ink sm:text-5xl">
        {post.data.title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-ink/75">{post.data.description}</p>
      <div class="mt-6 flex items-center gap-4 text-sm text-ink/50">
        <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
        <span aria-hidden="true">·</span>
        <span>MyGirlHub Editorial</span>
      </div>
    </header>

    <div
      class="article-body mt-10 space-y-6 text-base leading-relaxed text-ink/85 [&_h2]:mt-10 [&_h2]:font-serif [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:text-ink [&_h3]:mt-8 [&_h3]:font-serif [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:text-ink [&_a]:font-medium [&_a]:text-sage [&_a]:underline-offset-2 hover:[&_a]:underline [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6 [&_ol]:list-decimal [&_ol]:space-y-2 [&_ol]:pl-6 [&_strong]:text-ink"
    >
      <Content />
    </div>

    <MedicalDisclaimerBanner />
  </article>

  <SiteFooter slot="footer" />
</BaseLayout>
