---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PractitionerIntakeBanner from '../components/PractitionerIntakeBanner.astro';
import { telehealthPartners } from '../data/telehealth';
---

<BaseLayout
  title="Wellness Directory — Telehealth & Practitioner Network | MyGirlHub"
  description="Licensed online therapy through BetterHelp and Talkspace affiliate partners, plus apply to list your verified wellness practice on MyGirlHub."
>
  <SiteHeader slot="header" />

  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:py-16 lg:px-8">
    <header class="max-w-3xl">
      <p class="text-sm font-medium uppercase tracking-widest text-sage-light">MyGirlHub Directory</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold text-ink sm:text-5xl">
        Care you can access now — listings for professionals coming soon
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-ink/75">
        We do not list fictional profiles. This page connects you with established telehealth networks
        (affiliate partners we may earn from) and opens applications for real, verified practitioners.
      </p>
    </header>

    <!-- Section 1: Telehealth & affiliate networks -->
    <section class="mt-16" aria-labelledby="telehealth-heading">
      <div class="border-b border-stone pb-6">
        <h2 id="telehealth-heading" class="font-serif text-3xl font-semibold text-ink">
          Telehealth &amp; Network Directory
        </h2>
        <p class="mt-2 max-w-2xl text-sm text-ink/70">
          National and global platforms with licensed clinicians. MyGirlHub may receive a commission if
          you sign up through these links — at no extra cost to you.
          <a href="/disclaimer/" class="font-medium text-sage hover:underline">Disclosures</a>
        </p>
      </div>

      <ul class="mt-10 grid gap-8 lg:grid-cols-2">
        {
          telehealthPartners.map((partner) => (
            <li>
              <article class="flex h-full flex-col overflow-hidden rounded-2xl border border-stone bg-cream shadow-sm transition hover:border-sage/30 hover:shadow-md">
                <div class="relative aspect-[16/9] overflow-hidden bg-stone">
                  <img
                    src={partner.image}
                    alt={partner.imageAlt}
                    class="h-full w-full object-cover"
                    loading="lazy"
                    width="800"
                    height="450"
                  />
                  <span class="absolute left-4 top-4 rounded-full bg-cream/95 px-3 py-1 text-xs font-semibold text-sage shadow-sm">
                    Affiliate partner
                  </span>
                </div>
                <div class="flex flex-1 flex-col p-6 sm:p-8">
                  <p class="text-xs font-semibold uppercase tracking-wide text-sage-light">
                    {partner.tagline}
                  </p>
                  <h3 class="mt-2 font-serif text-2xl font-semibold text-ink">{partner.name}</h3>
                  <p class="mt-3 flex-1 text-sm leading-relaxed text-ink/75">{partner.description}</p>
                  <ul class="mt-4 space-y-2 text-sm text-ink/70">
                    {partner.features.map((feature) => (
                      <li class="flex gap-2">
                        <span class="text-sage" aria-hidden="true">✓</span>
                        {feature}
                      </li>
                    ))}
                  </ul>
                  <a
                    href={partner.ctaHref}
                    target="_blank"
                    rel="noopener noreferrer sponsored"
                    class="mt-8 inline-flex items-center justify-center rounded-xl bg-sage px-6 py-3.5 text-sm font-semibold text-cream transition hover:bg-sage-dark focus-visible:ring-2 focus-visible:ring-sage focus-visible:ring-offset-2"
                  >
                    {partner.ctaLabel}
                    <span class="sr-only"> (opens in new tab)</span>
                    <span aria-hidden="true" class="ml-1.5">↗</span>
                  </a>
                </div>
              </article>
            </li>
          ))
        }
      </ul>

      <p class="mt-8 rounded-xl border border-stone bg-stone/40 px-4 py-3 text-xs leading-relaxed text-ink/60">
        <strong class="text-ink/80">Important:</strong> MyGirlHub is not a healthcare provider. These
        platforms employ or contract their own licensed professionals. If you are in crisis in Australia,
        call <strong>000</strong> or Lifeline <strong>13 11 14</strong>.
      </p>
    </section>

    <!-- Section 2: Practitioner intake -->
    <section class="mt-20" aria-labelledby="intake-section-heading">
      <h2 id="intake-section-heading" class="sr-only">Practitioner intake portal</h2>
      <PractitionerIntakeBanner />
    </section>
  </div>

  <SiteFooter slot="footer" />
</BaseLayout>
