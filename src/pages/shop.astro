---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CuratedWellnessEdit from '../components/CuratedWellnessEdit.astro';
import { images } from '../data/images';
---

<BaseLayout
  title="The Curated Wellness Edit — Shop | MyGirlHub"
  description="Premium wellness products: cycle syncing planner PDF, In the FLO, BetterHelp therapy, and editor-picked self-care essentials."
>
  <SiteHeader slot="header" />

  <section class="relative border-b border-stone overflow-hidden">
    <img
      src={images.hero}
      alt="Woman practicing mindfulness in a calm, sunlit space"
      class="absolute inset-0 h-full w-full object-cover"
      width="1600"
      height="900"
    />
    <div class="absolute inset-0 bg-ink/50" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
      <p class="text-sm font-medium uppercase tracking-widest text-cream/80">MyGirlHub Shop</p>
      <h1 class="mt-3 max-w-2xl font-serif text-4xl font-semibold text-cream sm:text-5xl">
        The Curated Wellness Edit
      </h1>
      <p class="mt-4 max-w-xl text-lg text-cream/90">
        Hand-picked resources for burnout recovery, cycle syncing, and nervous-system care — vetted by
        our editorial team for quality and relevance.
      </p>
    </div>
  </section>

  <CuratedWellnessEdit compact={false} showViewAll={false} />

  <section class="border-t border-stone bg-stone/30 py-12">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="font-serif text-xl font-semibold text-ink">Gumroad &amp; Stripe ready</h2>
      <p class="mt-3 text-sm leading-relaxed text-ink/70">
        Replace the placeholder checkout URL in <code class="rounded bg-cream px-1.5 py-0.5 text-xs">src/data/shop.ts</code>
        with your live Stripe Payment Link or Gumroad product URL. Affiliate buttons use your Amazon
        Associates tag template (<code class="rounded bg-cream px-1.5 py-0.5 text-xs">mygirlhub-22</code>).
      </p>
    </div>
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
