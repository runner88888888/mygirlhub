---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import NewsletterCapture from '../components/NewsletterCapture.astro';
import CuratedWellnessEdit from '../components/CuratedWellnessEdit.astro';
import PractitionerIntakeBanner from '../components/PractitionerIntakeBanner.astro';
import { getCollection } from 'astro:content';
import { images } from '../data/images';
import { telehealthPartners } from '../data/telehealth';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const featuredPosts = [...allPosts]
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-AU', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="MyGirlHub — Wellness, Mental Health & Self-Care for Women"
  description="A credible wellness publication for women: mental health insights, cycle syncing guides, burnout recovery, curated shop, and practitioner directory."
>
  <SiteHeader slot="header" />

  <section class="relative border-b border-stone overflow-hidden">
    <img
      src={images.hero}
      alt="Woman practicing mindfulness in a peaceful setting"
      class="absolute inset-0 h-full w-full object-cover"
      width="1600"
      height="900"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ink/70 via-ink/50 to-ink/30" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
      <p class="text-sm font-medium uppercase tracking-widest text-cream/80">Welcome to MyGirlHub</p>
      <h1 class="mt-4 max-w-3xl font-serif text-4xl font-semibold leading-tight text-cream sm:text-5xl lg:text-6xl">
        Wellness that feels calm, credible, and entirely yours.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-cream/90">
        Evidence-informed articles, vetted practitioners, and a curated shop for burnout recovery,
        cycle syncing, and nervous-system care — built for Australian women.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/blog/"
          class="inline-flex items-center rounded-xl bg-sage px-6 py-3 text-sm font-semibold text-cream transition hover:bg-sage-dark"
        >
          Explore articles
        </a>
        <a
          href="/shop/"
          class="inline-flex items-center rounded-xl border border-cream/40 bg-cream/10 px-6 py-3 text-sm font-semibold text-cream backdrop-blur-sm transition hover:bg-cream/20"
        >
          Shop the Wellness Edit
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8" aria-labelledby="featured-heading">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 id="featured-heading" class="font-serif text-3xl font-semibold text-ink">
          Featured articles
        </h2>
        <p class="mt-2 text-ink/70">Deep reads on burnout, cycle syncing, and daily self-care.</p>
      </div>
      <a href="/blog/" class="text-sm font-semibold text-sage hover:underline">View all →</a>
    </div>

    <ul class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        featuredPosts.map((post) => (
          <li class="relative">
            <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-stone bg-cream shadow-sm transition hover:border-sage/30 hover:shadow-md">
              <div class="aspect-[16/10] overflow-hidden bg-stone">
                {post.data.image ? (
                  <img
                    src={post.data.image}
                    alt=""
                    class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
                    loading="lazy"
                    width="800"
                    height="500"
                  />
                ) : null}
              </div>
              <div class="flex flex-1 flex-col p-6">
                <span class="text-xs font-semibold uppercase tracking-wide text-sage-light">
                  {post.data.category}
                </span>
                <h3 class="mt-2 font-serif text-xl font-semibold text-ink group-hover:text-sage">
                  <a href={`/blog/${post.id}/`} class="before:absolute before:inset-0">
                    {post.data.title}
                  </a>
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-ink/70 line-clamp-3">
                  {post.data.description}
                </p>
                <time datetime={post.data.pubDate.toISOString()} class="mt-4 text-xs text-ink/50">
                  {formatDate(post.data.pubDate)}
                </time>
              </div>
            </article>
          </li>
        ))
      }
    </ul>
  </section>

  <CuratedWellnessEdit compact showViewAll />

  <section class="bg-stone/30 py-16" aria-labelledby="directory-preview-heading">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2 id="directory-preview-heading" class="font-serif text-3xl font-semibold text-ink">
            Telehealth &amp; care networks
          </h2>
          <p class="mt-2 max-w-xl text-ink/70">
            Licensed online therapy — or apply to list your verified practice when our directory opens.
          </p>
        </div>
        <a href="/directory/" class="text-sm font-semibold text-sage hover:underline">Full directory →</a>
      </div>

      <ul class="mt-10 grid gap-6 md:grid-cols-2">
        {
          telehealthPartners.map((partner) => (
            <li class="rounded-2xl border border-stone bg-cream p-6 shadow-sm">
              <p class="text-xs font-semibold uppercase tracking-wide text-sage-light">{partner.tagline}</p>
              <h3 class="mt-2 font-serif text-xl font-semibold text-ink">{partner.name}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/75 line-clamp-3">{partner.description}</p>
              <a
                href={partner.ctaHref}
                target="_blank"
                rel="noopener noreferrer sponsored"
                class="mt-4 inline-flex text-sm font-semibold text-sage hover:underline"
              >
                {partner.ctaLabel} ↗
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-10">
        <PractitionerIntakeBanner compact />
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8">
    <NewsletterCapture />
  </section>

  <SiteFooter slot="footer" />
</BaseLayout>
